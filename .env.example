GHL_API_KEY=pit-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
GHL_LOCATION_ID=XXXXXXXXXXXXXXXXXXXXXXXX
GHL_USER_ID=XXXXXXXXXXXXXXXXXXXXXXXX

# Supabase
SUPABASE_URL=https://XXXXXX.supabase.co
SUPABASE_ANON_KEY=eyXXXXXX
SUPABASE_SERVICE_KEY=eyXXXXXX

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
ADMIN_SECRET=your-random-secret-for-tokens

# Slack (notifications #suivi-client-bbp)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXX

# Stripe (paiement)
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX
STRIPE_PRODUCT_ID=prod_XXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXX

# GHL Documents (nom du template de contrat)
GHL_CONTRACT_TEMPLATE_NAME=CONTRAT BBP - CLIENT

# GHL Calendar (lien de réservation onboarding — appel de cadrage 30min)
NEXT_PUBLIC_GHL_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/XXXXX

# GHL Filming Calendar (lien de réservation tournage — créneau 3h, embed
# affiché côté portail dès que le client valide son script). Si non défini,
# le portail retombe sur NEXT_PUBLIC_GHL_CALENDAR_URL.
# IMPORTANT : configure GHL pour 1 seul créneau de 3h par jour pour matcher
# la contrainte côté Bourbomedia (vérification d'unicité au moment du booking).
NEXT_PUBLIC_GHL_FILMING_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/XXXXX

# GHL Closing Calendar (lien sales/closing avant onboarding) — utilisé
# typiquement depuis la landing publique. Pas utilisé par le portail/dashboard
# pour le moment, à conserver pour des intégrations futures.
NEXT_PUBLIC_GHL_CLOSING_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/XXXXX

# GHL Contract (lien public de signature)
NEXT_PUBLIC_GHL_CONTRACT_URL=https://sendlink.co/documents/doc-form/XXXXX?locale=fr-FR

# Next.js public (client-side)
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXX

# Cron jobs (Vercel Cron — auto-reminders for stuck clients, Mon-Fri 7am)
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# Feature flag: set to "true" to enable automatic client notifications
# (WhatsApp + email via GHL) on script send and video delivery.
# Keep disabled until templates are validated.
NOTIFICATIONS_ENABLED=false

# 🚨 KILL SWITCH global pour TOUS les envois automatiques client-facing.
# Quand "true" : aucun WhatsApp/SMS/Email n'est envoyé, et aucun tag GHL
# (bbm_*) n'est ajouté à un contact (donc aucun workflow GHL ne se déclenche).
# Les notifs Slack internes et les notifs in-app restent actives.
# À mettre à "true" tant que les templates GHL ne sont pas finalisés.
AUTOMATIONS_PAUSED=true

# Anthropic Claude — pour le bouton "✨ IA" de l'éditeur de script
# (reformuler / raccourcir / étoffer / corriger / suggérer accroche|CTA).
# Sans clé : le bouton renvoie une erreur "fonctionnalité bientôt disponible".
ANTHROPIC_API_KEY=sk-ant-XXXXXXXX
