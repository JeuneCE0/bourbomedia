GHL_API_KEY=pit-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
GHL_LOCATION_ID=XXXXXXXXXXXXXXXXXXXXXXXX
GHL_USER_ID=XXXXXXXXXXXXXXXXXXXXXXXX

# Supabase
SUPABASE_URL=https://XXXXXX.supabase.co
SUPABASE_ANON_KEY=eyXXXXXX
SUPABASE_SERVICE_KEY=eyXXXXXX

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
ADMIN_SECRET=your-random-secret-for-tokens

# Slack (notifications #suivi-client-bbp)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXX

# Stripe (paiement)
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX
STRIPE_PRODUCT_ID=prod_XXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXX

# GHL Documents (nom du template de contrat)
GHL_CONTRACT_TEMPLATE_NAME=CONTRAT BBP - CLIENT

# ─────────────────────────────────────────────────────────────────────────
# GHL Calendars — URLs CANONIQUES PERMANENTES (ne changent pas dans le
# temps, alignées sur les IDs internes GHL). Les URLs slug-based de GHL
# (ex: /widget/bookings/appel-avec-simon...) peuvent rotater si le slug
# est régénéré côté GHL ; les URLs ID-based ci-dessous sont stables.
#
# Le composant GhlBookingEmbed normalise toute valeur saisie ici et tombe
# sur ces IDs en dernier recours si l'env var est mal configurée — donc
# le portail reste fonctionnel même sans toucher à Vercel.
# ─────────────────────────────────────────────────────────────────────────

# GHL Calendar — appel onboarding (cadrage 30min)
NEXT_PUBLIC_GHL_ONBOARDING_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/2fmSZkWpwEulfZsvpPmh

# Legacy : utilisé par le portail comme fallback si ONBOARDING_CALENDAR_URL
# n'est pas défini. À garder identique à NEXT_PUBLIC_GHL_ONBOARDING_CALENDAR_URL
# tant qu'on n'a pas migré tous les callers.
NEXT_PUBLIC_GHL_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/2fmSZkWpwEulfZsvpPmh

# GHL Filming Calendar (lien de réservation tournage — créneau 3h, embed
# affiché côté portail dès que le client valide son script).
# IMPORTANT : configure GHL pour 1 seul créneau de 3h par jour pour matcher
# la contrainte côté Bourbomedia (vérification d'unicité au moment du booking).
NEXT_PUBLIC_GHL_FILMING_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/vKw4x99jCNnZnl5FuSig

# GHL Publication Calendar (lien de réservation date de publication, mardi
# ou jeudi uniquement, embed affiché côté portail après validation de la
# vidéo).
NEXT_PUBLIC_GHL_PUBLICATION_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/RRDC3HvypJEIvLxjy3Gg

# GHL Closing Calendar (lien sales/closing avant onboarding) — utilisé
# typiquement depuis la landing publique. Pas utilisé par le portail/dashboard
# pour le moment, à conserver pour des intégrations futures.
NEXT_PUBLIC_GHL_CLOSING_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/Lc0QRopqpKqER5Xecqhs

# GHL Contract (lien public de signature)
NEXT_PUBLIC_GHL_CONTRACT_URL=https://sendlink.co/documents/doc-form/XXXXX?locale=fr-FR

# Next.js public (client-side)
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXX

# Cron jobs (Vercel Cron — auto-reminders for stuck clients, Mon-Fri 7am)
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# Feature flag: set to "true" to enable automatic client notifications
# (WhatsApp + email via GHL) on script send and video delivery.
# Keep disabled until templates are validated.
NOTIFICATIONS_ENABLED=false

# 🚨 KILL SWITCH global pour TOUS les envois automatiques client-facing.
# Quand "true" : aucun WhatsApp/SMS/Email n'est envoyé, et aucun tag GHL
# (bbm_*) n'est ajouté à un contact (donc aucun workflow GHL ne se déclenche).
# Les notifs Slack internes et les notifs in-app restent actives.
# À mettre à "true" tant que les templates GHL ne sont pas finalisés.
AUTOMATIONS_PAUSED=true

# Anthropic Claude — pour le bouton "✨ IA" de l'éditeur de script
# (reformuler / raccourcir / étoffer / corriger / suggérer accroche|CTA).
# Sans clé : le bouton renvoie une erreur "fonctionnalité bientôt disponible".
ANTHROPIC_API_KEY=sk-ant-XXXXXXXX

# ============================================================
# GHL Appointments (sync bidirectionnel notes post-call)
# ============================================================
# IDs des calendriers GHL (depuis Settings → Calendars → URL ou API).
# On classe chaque rendez-vous reçu par webhook selon le calendrier d'origine
# pour adapter la notif Slack et la fiche admin.
GHL_CLOSING_CALENDAR_ID=Lc0QRopqpKqER5Xecqhs
GHL_ONBOARDING_CALENDAR_ID=2fmSZkWpwEulfZsvpPmh
GHL_FILMING_CALENDAR_ID=vKw4x99jCNnZnl5FuSig

# Secret partagé avec le webhook GHL — protège l'endpoint
#   POST /api/webhooks/ghl/appointment?secret=<GHL_WEBHOOK_SECRET>
# Configure côté GHL : Workflows → trigger "Appointment" → action "Webhook"
# avec l'URL ci-dessus et l'événement "Appointment Status Changed".
# Génère un secret : openssl rand -hex 32
GHL_WEBHOOK_SECRET=replace-with-random-hex-secret
